# =============================================================
# Binance API Credentials
# Get keys from: https://www.binance.com/en/my/settings/api-management
# =============================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Set to true to use Binance testnet (paper trading)
# Set to false or omit for live mainnet trading
USE_TESTNET=true

# =============================================================
# Trading Configuration
# =============================================================
# Trading pair to operate on (user-selected digital assets)
TRADING_SYMBOLS=BTC/USDT

# Timeframe for candles (1h, 15m, 5m, etc.)
TRADING_TIMEFRAME=1h

# Maximum position size as % of total balance (fractional Kelly)
MAX_POSITION_SIZE_PCT=0.05

# Hardcoded stop-loss per position (5% below entry)
STOP_LOSS_PCT=0.05

# Hardcoded take-profit per position (10% above entry)
TAKE_PROFIT_PCT=0.10

# Maximum daily loss % before circuit breaker
MAX_DAILY_LOSS_PCT=0.02

# Maximum drawdown % before full system halt
MAX_DRAWDOWN_PCT=0.10

# Cooldown minutes after circuit breaker triggers
COOLDOWN_MINUTES=60

# =============================================================
# ML / Training (Research Lab)
# =============================================================
# Wandb for experiment tracking (optional, leave empty to disable)
WANDB_PROJECT=auto-trading
WANDB_API_KEY=

# Number of autoresearch iterations per run
AUTORESEARCH_ITERATIONS=100

# Max training minutes per mutation (cap to avoid overtraining)
MAX_TRAIN_MINUTES=5

# =============================================================
# Logging
# =============================================================
LOG_LEVEL=INFO
LOG_FILE=logs/trading.log

# =============================================================
# MiroFish Integration (Phase 11, optional for now)
# =============================================================
ZEP_API_KEY=
LLM_API_KEY=
LLM_MODEL=
